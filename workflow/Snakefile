################################################################################
# SNAKEMAKE SETUP
################################################################################

from snakemake.utils import min_version
min_version("8.0")


configfile: 'config/config_aadrita.yaml'
# Extract dataset names dynamically
DATASETS = list(config["summary_statistics"].keys()) 

#print("Loaded datasets:", DATASETS)


# Debugging: Print entire summary_statistics structure
import json
#print("Full summary_statistics config:", json.dumps(config["summary_statistics"], indent=4))

COHORTS = list(config["cohort"].keys())
#print("Loaded cohort:", COHORTS)
CHROMS  = config["PRScs-auto"]["chromosomes"]
#print("Loaded chromosomes:", CHROMS)
PHIS    = config["PRScs-auto"]["phi"]
#print("Loaded phis:", PHIS)



# Summary statistics
#POPULATION = list(config["summary_statistics"].keys())
#SAMPLE_SIZES = [str(details["sample_size"]) for details in config["summary_statistics"].values()]
SAMPLE_SIZES = lambda wc: config["summary_statistics"][wc.dataset]["sample_size"]
SS = [details["sst_file"] for details in config["summary_statistics"].values()]
SST = config["PRScs-auto"]["sst_file"]
#print("Loaded summary statistics:", SS)
REF_LD = config["PRScs-auto"]["ref_ld"]
#print("Loaded reference LD:", REF_LD)

shell.executable('/bin/bash')
################################################################################
# FINAL RULE: Compile all resulting score files
################################################################################
rule all:
    input:
        expand(
            "results/{dataset}/{cohort}_phi{phi}_chrAll_noAPOE_pgsc_calc.txt",
            dataset=DATASETS,
            cohort=COHORTS if COHORTS else ["ADGC"],# Fallback default
            phi=PHIS
        ),
        expand(
            "results/{dataset}/{cohort}_phi{phi}_chrAll_noAPOE_scores.txt",
            dataset=DATASETS,
            cohort=COHORTS if COHORTS else ["ADGC"],# Fallback default
            phi=PHIS
        ),
        expand(
            "results/{dataset}/{cohort}_phi{phi}_chrAll.txt",
            dataset=DATASETS,
            cohort=COHORTS if COHORTS else ["ADGC"],# Fallback default
            phi=PHIS
        )

################################################################################
# RULE 1: MUNGE SUMMARY STATISTICS
################################################################################
rule format_prscs:
    """
    Converts raw summary statistics into a format suitable for PRS-CS Auto.
    """
    input: 
        "data/{dataset}.chrall.CPRA_b37.tsv.gz"
    output:
        "work/formatted/{dataset}_formated_ss.txt"
    singularity: "docker://codewithrakshya/mungesumstats_docker"
    threads: 2
    resources:
        mem_mb=32000,
        time_min=1200
    script:
        'scripts/format_sumstats.R'

################################################################################
# RULE 2: MUNGE BIM / PVAR -> BED/BIM/FAM
################################################################################
rule munge_bim:
    """
    Reads a .pvar file, reformats it, and generates a SNP mapping file (cpra2rsids.txt).
    """
    input:
        pvar="resources/{cohort}/out.pvar"
    output:
        name_file="resources/{cohort}/cpra2rsids.txt"
    singularity: "docker://codewithrakshya/mungesumstats_docker"
    threads: 1
    resources:
        mem_mb=8000,
        time_min=300
    script: "scripts/munge_bim.R"


################################################################################
# RULE 3: RUN PLINK2 TO UPDATE VARIANT IDS
################################################################################

rule run_plink:
    """
    Uses PLINK2 to update variant IDs in the genotype files.
    """
    input:
        name_file="resources/{cohort}/cpra2rsids.txt"
    output:
        bed="resources/{cohort}/adgc.bed",
        bim="resources/{cohort}/adgc.bim",
        fam="resources/{cohort}/adgc.fam"
    params:
        plink_prefix="resources/ADGC/out",
        plink_out="resources/ADGC/adgc"
    conda : "envs/plink.yaml"
    threads: 4
    resources:
        mem_mb=16000,  # 16GB RAM
        time_min=600   # 10 hours
    shell:
        """
        plink2 --pfile {params.plink_prefix} \
               --update-name {input.name_file} \
               --keep-allele-order \
               --make-bed \
               --out {params.plink_out}
        """

################################################################################
# RULE 3: PREPARE HAPMAP3 SNP LIST (OPTIONAL) Not Used
################################################################################
rule prepare_hm3:
    """
    Creates a list of HapMap3 SNPs (one ID per line) that will be used for filtering.
    """
    input:
        "resources/snpinfo_mult_1kg_hm3"
    output:
        "resources/w_hm3.snplist"
    shell:
        "cut -f1 {input} > {output}"

################################################################################
# RULE 4: FILTER GENOTYPE DATA TO HAPMAP3 SNPs
################################################################################
rule plink_filter:
    """
    Filters the genotype data (in PLINK format) to only HapMap3 SNPs.
    """
    input:
        bed = rules.run_plink.output.bed,
        bim = rules.run_plink.output.bim,
        fam = rules.run_plink.output.fam,
        hm3 = "resources/w_hm3.snplist"
    output:
        multiext("resources/hm3/{cohort}_hm3", ".bed", ".bim", ".fam")
    conda:
        "envs/plink.yaml"
    threads: 2
    resources:
        mem_mb=16000,  # 16GB RAM
        time_min=600   # 10 hours
    shell:
        """
        plink --bfile resources/{wildcards.cohort}/adgc \
              --extract {input.hm3} \
              --make-bed \
              --out resources/hm3/{wildcards.cohort}_hm3
        """

################################################################################
# RULE 5: RUN PRS-CS AUTO (per chromosome, per cohort, per PHI)
################################################################################

rule prscs_auto:
    """
    Runs PRS-CS Auto for each chromosome.
    """
    input:
        summary_stats = "work/formatted/{dataset}_formated_ss.txt",
        bfiles = lambda wc: [
            f"resources/hm3/{wc.cohort}_hm3.bed",
            f"resources/hm3/{wc.cohort}_hm3.bim",
            f"resources/hm3/{wc.cohort}_hm3.fam"]
    output:
        "results/{dataset}/{cohort}_pst_eff_a1_b0.5_phi{phi}_chr{chrom}.txt"
    params:
        #bim_prefix = f"resources/{COHORTS[0]}_hm3",
        bim_prefix = lambda wc: f"resources/hm3/{wc.cohort}_hm3",
        #phi_arg = lambda wildcards: f"--phi={PHIS}" if PHIS != 'auto' else '',
        phi_arg = lambda wc: f"--phi={wc.phi}" if wc.phi != 'auto' else '',
        chrom = "{chrom}",
        ss = SST,
        n = SAMPLE_SIZES,
        ref_ld = REF_LD

    conda:
        "envs/prscs.yaml"
    threads: 4
    resources:
        mem_mb=6400,
        time_min=1800
    shell:
        """
        python resources/PRScs/PRScs.py \
          --ref_dir={params.ref_ld}\
          --bim_prefix={params.bim_prefix} \
          --sst_file {params.ss} \
          --n_gwas={params.n} \
          --chrom={params.chrom} \
            {params.phi_arg} \
          --out_dir=results/{wildcards.dataset}/{wildcards.cohort}
        """

################################################################################
# RULE 6: CONCATENATE CHR-SPECIFIC PRS WEIGHTS
################################################################################
rule concat_chrom_files:
    """
    Concatenates PRS-CS output from all chromosomes.
    """
    input:
        expand(
            "results/{{dataset}}/{{cohort}}_pst_eff_a1_b0.5_phi{{phi}}_chr{chrom}.txt",
            dataset=DATASETS,
            chrom=CHROMS
        )
    output:
        "results/{dataset}/{cohort}_phi{phi}_chrAll.txt"
    shell:
        "cat {input} > {output}"

################################################################################
# RULE 7: REMOVE APOE REGION
################################################################################
rule rm_apoe:
    """
    Removes the APOE region (chr19:44,408,822-45,408,822) from final PRS weights.
    """
    input:rules.concat_chrom_files.output
    output:
        "results/{dataset}/{cohort}_phi{phi}_chrAll_noAPOE.txt"
    shell:
        """
        awk '$1 != 19 || ($1 == 19 && ($3 < 44408822 || $3 > 45408822))' {input} > {output}
        """

################################################################################
# RULE 8: SCORE WITH PLINK
################################################################################
rule plink_score:
    """
    Uses PLINK to score individuals with the final PRS weights.
    """
    input:
        bfiles  = rules.plink_filter.output,
        weights = rules.rm_apoe.output
    output:
        "results/{dataset}/{cohort}_phi{phi}_chrAll_noAPOE_scores.txt"
    params:
        bfile = lambda wc: f"resources/hm3/{wc.cohort}_hm3"
    conda:
        "envs/plink.yaml"
    shell:
        """
        plink --bfile {params.bfile} \
              --score {input.weights} 2 4 6 sum \
              --out results/{wildcards.dataset}/{wildcards.cohort}_{wildcards.phi}_chrAll_noAPOE_scores

        mv results/{wildcards.dataset}/{wildcards.cohort}_{wildcards.phi}_chrAll_noAPOE_scores.profile {output}
        """

################################################################################
# RULE 9: COMPILE ALL SCORE FILES FOR PGSC_CALC
################################################################################
rule make_pgsc_calc_format:
    """
    Convert the final PRS-CS Auto output (after APOE removal) into a pgsc_calc-compatible file.
    """
    input:
        # Takes the rm_apoe output
        "results/{dataset}/{cohort}_phi{phi}_chrAll_noAPOE.txt"
    output:
        # The new pgsc_calc-formatted file
        "results/{dataset}/{cohort}_phi{phi}_chrAll_noAPOE_pgsc_calc.txt"
    shell:
        # Example approach using awk
        """
        awk 'BEGIN {{
          print "#pgs_name={wildcards.cohort}_phi{wildcards.phi}_pst_eff_a1_b0.5_phiauto"
          print "#trait_reported={wildcards.dataset}"
          print "#genome_build=GRCh37"
          print "#pgs_id=custom"
          print "chr_name\\tchr_position\\teffect_allele\\tother_allele\\teffect_weight"
        }}
        {{
          # In final PRS-CS file, columns are typically:
          # $1=CHR, $2=RSID, $3=POS, $4=A1, $5=A2, $6=WEIGHT
          print $1"\\t"$3"\\t"$4"\\t"$5"\\t"$6
        }}' {input} > {output}
        """