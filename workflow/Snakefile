import glob
import os
def choose_prscs_input(wc):
    pattern = f"data/{wc.dataset}*.tsv.gz"
    candidates = glob.glob(pattern)
    if not candidates:
        raise ValueError(f"No file found matching {pattern}")
    if len(candidates) > 1:
        print(f"Warning: multiple matches for {wc.dataset}, using first: {candidates}")
    chosen = candidates[0]
    print(f"Using summary‐stats file for dataset {wc.dataset}: {chosen}")
    return chosen

from snakemake.utils import min_version
min_version("8.0")


